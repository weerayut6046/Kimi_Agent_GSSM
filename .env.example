VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side / CI secrets (not used by the browser app)
# Required for Supabase Edge Functions and GitHub Actions database backup
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# GitHub configuration for triggering database backup from the web app
# GITHUB_PAT must have 'repo' or 'actions:write' permission
GITHUB_PAT=ghp_xxx
GITHUB_REPO_OWNER=your-github-username-or-org
GITHUB_REPO_NAME=gas-station-shift-manager
